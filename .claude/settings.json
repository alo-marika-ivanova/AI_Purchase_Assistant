{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./attachments/**)",
      "Read(./uploads/**)",
      "Read(./*.db)",
      "Read(./*.sqlite)",
      "Read(./*.sqlite3)"
    ]
  }
}