# Database (optional; defaults to purchasing_ai.sqlite3 in the project root)
# PURCHASING_AI_DB_PATH=C:\path\to\purchasing_ai.sqlite3

# Local Ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.1
OLLAMA_CLASSIFIER_TIMEOUT_SECONDS=60
USE_LLM_COMMUNICATION_WRITER=true
DEFAULT_NEGOTIATION_CURRENCY=USD
ASSUME_DEFAULT_CURRENCY_FROM_CONTEXT=true

# SMTP outbound email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_DRY_RUN=false

# Microsoft Graph inbound email
BUYER_EMAIL=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=
EMAIL_IGNORE_SENDERS=

# Optional email test routing
EMAIL_TEST_MODE=false
EMAIL_TEST_SUPPLIER_TO=

# Workflow worker
EMAIL_WORKER_ENABLED=true
EMAIL_WORKER_POLL_SECONDS=20
EMAIL_WORKER_CASE_ID=
EMAIL_WORKER_DEBUG=false

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_AUTO_CONTINUE_NEGOTIATION=true
