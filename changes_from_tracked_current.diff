+            SELECT id, unit_price_usd, status
+            FROM offers
+            WHERE case_id = ?
+              AND supplier_id = ?
+            ORDER BY id
+            """,
+            (case_id, supplier_id),
+        ).fetchall()
+    return [dict(row) for row in rows]
+
